# OpenAI API key — required for character generation
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# Neon Postgres connection string — required for character persistence
# Set up via Vercel Marketplace (Neon integration) or https://neon.tech
DATABASE_URL=postgresql://user:password@host/dbname

# Auth.js secret — required for signing/encrypting session JWTs
# Generate with: openssl rand -base64 32
AUTH_SECRET=your-secret-here
